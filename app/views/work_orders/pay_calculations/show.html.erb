<div id="work_orders_pay_calculations" class="container-fluid px-4 py-4 pay-calculations" data-controller="multi-sort">
  <%= render 'shared/breadcrumb', breadcrumbs: [
    ['Work Order', '#'],
    ['Pay Calculation', work_orders_pay_calculations_path],
    [(Date.strptime(@pay_calculation.month_year, '%Y-%m').strftime('%B %Y') rescue @pay_calculation.month_year), nil],
    ['Workers', nil]
  ] %>
  <!-- Back Button and Export -->
  <div class="mb-3 d-flex justify-content-between align-items-center">
    <%= link_to work_orders_pay_calculations_path, class: "text-decoration-none text-dark d-inline-flex align-items-center fs-5 fw-bold" do %>
      <i class="bi bi-arrow-left me-2"></i> Back to Calculation
    <% end %>
    <div class="d-flex gap-2">
      <% export_params = { format: :csv } %>
      <% export_params[:q] = params[:q].to_unsafe_h if params[:q].present? %>
    <button type="button"
            class="btn btn-sm"
            style="background-color: #28a745; color: white;"
            data-bs-toggle="modal"
            data-bs-target="#exportCsvModal">
      <i class="bi bi-file-earmark-spreadsheet text-white me-1"></i>
      Export CSV
    </button>
    </div>
  </div>
  <hr>
  <!-- Workers Table -->
  <div class="card shadow-sm">
    <div class="card-body">
      <%= search_form_for @q, url: work_orders_pay_calculation_path(@pay_calculation), method: :get, html: { id: 'worker-details-search-form', data: { controller: "search-form", action: "submit->search-form#resetPage" } } do |f| %>
        <div class="table-responsive">
          <table class="table table-hover table-sm mb-0">
            <thead class="header-row">
              <tr class="header-row">
                <th class="text-center"></th>
                <th class="text-center">
                  <%= sort_link(@q, :worker_id, 'Worker ID') %>
                </th>
                <th class="text-center">
                  <%= sort_link(@q, :worker_name, 'Worker Name') %>
                </th>
                <th class="text-center">
                  <%= sort_link(@q, :net_salary, 'Net Salary (RM)') %>
                </th>
              </tr>
              <tr>
                <th class="text-center">
                  <div class="d-flex gap-1 justify-content-center">
                    <%= link_to 'Reset', work_orders_pay_calculation_path(@pay_calculation), class: 'btn btn reset-btn', style: "width: 120px;" %>
                  </div>
                </th>
                <th class="text-center">
                  <%= f.number_field :worker_id_eq, class: 'form-control form-control-sm', placeholder: 'Worker ID', min: 1, data: { action: "input->search-form#autoSubmit" } %>
                </th>
                <th class="text-center">
                  <%= f.search_field :worker_name_cont, class: 'form-control form-control-sm', placeholder: 'Search Worker Name..', data: { action: "input->search-form#autoSubmit" } %>
                </th>
                <th class="text-center">
                  <%= f.number_field :net_salary_eq, class: 'form-control form-control-sm', placeholder: 'Net Salary (RM)', step: '0.01', data: { action: "input->search-form#autoSubmit" } %>
                </th>
              </tr>
            </thead>
            <tbody>
              <% if @pay_calculation_details.any? %>
                <% @pay_calculation_details.each do |detail| %>
                  <tr>
                    <td class="text-center">
                      <div class="d-inline-flex gap-1 justify-content-center">
                        <%= link_to worker_detail_work_orders_pay_calculation_path(@pay_calculation, worker_id: detail.worker_id),
          class: "action-btn info",
          title: "View Details" do %>
                          <i class="bi bi-info-circle-fill"></i>
                        <% end %>
                      </div>
                    </td>
                    <td class="text-center"><%= detail.worker.id %></td>
                    <td class="text-center"><%= detail.worker.name %></td>
                    <td class="text-center"><%= number_to_currency(detail.net_salary, unit: 'RM ', separator: '.', delimiter: ',', precision: 2) %></td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="4" class="text-center text-muted py-4">
                    No worker details found for this pay calculation period.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
      <!-- Pagination -->
      <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="d-flex align-items-center gap-2">
          <span class="text-muted small">Show</span>
          <%= per_page_selector %>
          <span class="text-muted small">
            <%== @pagy.info_tag(item_name: 'Workers') %>
          </span>
        </div>
        <div>
          <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
        </div>
      </div>
    </div>
  </div>


  <div class="modal fade" id="exportCsvModal" tabindex="-1" aria-labelledby="exportCsvModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title" id="exportCsvModalLabel">
          <strong>Pay Calculation - Export CSV for <%= Date.strptime(@pay_calculation.month_year, '%Y-%m').strftime('%B %Y') rescue @pay_calculation.month_year %> </strong>
        </h5>

        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

<%= form_with url: work_orders_pay_calculation_path(@pay_calculation, format: :csv),
              method: :get,
              local: true,
              data: {
                turbo: false,
                controller: "export",
                action: "submit->export#submit"
              } do %>

        <div class="modal-body">

          <div class="alert alert-info d-none"
              data-export-target="status">
            <i class="bi bi-info-circle-fill me-2"></i>
            Exporting Excel file, please wait...
          </div>

          <p class="mb-3">
            Select worker categories to export:
          </p>

          <div class="form-check mb-2">
            <%= check_box_tag "worker_filters[]",
                              "local",
                              true,
                              class: "form-check-input",
                              id: "filter_local" %>

            <%= label_tag "filter_local",
                          "Local",
                          class: "form-check-label" %>
          </div>

          <div class="form-check mb-2">
            <%= check_box_tag "worker_filters[]",
                              "foreigner",
                              true,
                              class: "form-check-input",
                              id: "filter_foreigner" %>

            <%= label_tag "filter_foreigner",
                          "Foreigner",
                          class: "form-check-label" %>
          </div>

          <div class="form-check mb-2">
            <%= check_box_tag "worker_filters[]",
                              "foreigner_no_passport",
                              true,
                              class: "form-check-input",
                              id: "filter_foreigner_no_passport" %>

            <%= label_tag "filter_foreigner_no_passport",
                          "Foreigner (No Passport)",
                          class: "form-check-label" %>
          </div>

          <%# Preserve current search filters %>
          <% if params[:q].present? %>
            <% params[:q].each do |key, value| %>
              <%= hidden_field_tag "q[#{key}]", value %>
            <% end %>
          <% end %>

        </div>

    <div class="modal-footer">
      <button type="submit" class="btn btn-success w-100 py-2">
        <i class="bi bi-file-earmark-excel-fill text-white me-2"></i>
        Export CSV
      </button>
    </div>

      <% end %>

    </div>
  </div>
</div>
